# EMI Locker Environment Configuration
# Copy this file to .env and update the values

# Database
POSTGRES_USER=emilocker
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=emi_locker

# Security
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars

# Firebase (place your firebase-credentials.json in the root directory)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Optional: External services
# SENTRY_DSN=your-sentry-dsn-for-error-tracking
