# ── App ────────────────────────────────────────────────
APP_NAME="RR Locker API"
VERSION=1.0.0
DEBUG=true
PORT=7860

# ── Database ───────────────────────────────────────────
# SQLite (default). On Hugging Face / PaaS a persistent /data mount is used automatically.
DATABASE_URL=sqlite:///./emi_locker.db
# Postgres example:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── JWT ────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Firebase (FCM push) ────────────────────────────────
# Path to service-account JSON OR base64-encoded JSON in FIREBASE_CREDENTIALS_JSON
FIREBASE_CREDENTIALS_PATH=service-account.json
FIREBASE_CREDENTIALS_JSON=

# ── EMI ────────────────────────────────────────────────
DEFAULT_GRACE_PERIOD_DAYS=7
WARNING_DAYS_BEFORE_DUE=3

# ── APK download ───────────────────────────────────────
APK_DOWNLOAD_URL=https://riadrayhan111-rr-locker-api.hf.space/api/v1/app/download
APK_CHECKSUM=

# ── CORS (comma separated) ─────────────────────────────
CORS_ORIGINS=https://riadrayhan111-rr-locker-dashboard.static.hf.space,https://riadrayhan111-rr-locker-api.hf.space,http://localhost:3000,http://localhost:5173

# ── Android Management API (AMAPI) ─────────────────────
AMAPI_SERVICE_ACCOUNT_JSON=
AMAPI_PROJECT_ID=blooger-project
AMAPI_ENTERPRISE_NAME=enterprises/LC015xh0ii

# ── Keep-alive (prevent cold starts) ───────────────────
APP_EXTERNAL_URL=
