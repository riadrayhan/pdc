<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.RRLocker" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <style name="Theme.RRLocker.Transparent" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <style name="Theme.RRLocker.Lock" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/lock_background</item>
        <item name="colorPrimaryVariant">@color/lock_background</item>
        <item name="android:windowBackground">@color/lock_background</item>
        <item name="android:statusBarColor">@color/lock_background</item>
        <item name="android:navigationBarColor">@color/lock_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
