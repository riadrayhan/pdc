# Database (SQLite - local file based, no PostgreSQL needed)
DATABASE_URL=sqlite:///./emi_locker.db

# Redis (Optional)
REDIS_URL=redis://localhost:6379/0

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=your-super-secret-key-change-this-in-production-use-long-random-string

# Firebase - Place your firebase-credentials.json file in backend folder
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# EMI Settings
DEFAULT_GRACE_PERIOD_DAYS=7
WARNING_DAYS_BEFORE_DUE=3

# CORS Origins
CORS_ORIGINS=["https://rr-locker-api.onrender.com","http://localhost:3000","http://localhost:5173"]

# Debug Mode (set False in production)
DEBUG=False
